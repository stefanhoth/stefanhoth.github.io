---
import { getCollection, render } from "astro:content";
import TocSidebar from "@/components/TocSidebar.astro";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages", ({ data }) => data.publish);
  // A `permalink` frontmatter field overrides the filename-derived slug.
  // File-style permalinks (`.md` suffix) still build the folder-style page
  // here — the Worker serves it under the `.md` URL (see worker/index.js).
  return pages.map((page) => ({
    params: { slug: (page.data.permalink ?? page.id).replace(/\.md$/, "") },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);

// `template: sidebar` (frontmatter) renders the content with a sidebar
// linking to every h2. The headings come out of the markdown build, so a
// page without any h2s falls back to the plain template.
const useSidebar =
  page.data.template === "sidebar" &&
  headings.some((heading) => heading.depth === 2);

// `template: projects` renders every h2 section as a card — the wrapping
// happens at build time in src/lib/rehypeProjectCards.js; here we only
// set the body class the card styles are scoped to.
const useProjects = page.data.template === "projects";

const bodyClass = useSidebar
  ? "toc-page"
  : useProjects
    ? "projects-page"
    : undefined;
---

<Layout
  title={page.data.title}
  description={page.data.description}
  bodyClass={bodyClass}
>
  {
    useSidebar ? (
      <div class="toc-layout">
        <aside class="toc-col">
          <TocSidebar headings={headings} />
        </aside>
        <article class="prose">
          <Content />
        </article>
      </div>
    ) : (
      <article class="prose">
        <Content />
      </article>
    )
  }
</Layout>

<style>
  .toc-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .toc-layout {
      grid-template-columns: minmax(0, 600px) 220px;
      gap: 2.5rem;
    }

    /* Content left, sidebar right; it stays in view while scrolling. */
    .toc-col {
      order: 2;
      position: sticky;
      top: 2rem;
    }
  }
</style>

<style is:global>
  /* Layout.astro caps the body at 600px for the single-column pages;
     the sidebar template needs room for the extra column. */
  body.toc-page {
    max-width: 900px;
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  /* Breathing room above a heading after jumping to its anchor. */
  article.prose :is(h2, h3, h4) {
    scroll-margin-top: 1.5rem;
  }

  /* template: projects — each h2 section arrives pre-wrapped in
     <section class="project-card"> (src/lib/rehypeProjectCards.js). */
  body.projects-page .project-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin: 1.25rem 0;
  }

  body.projects-page .project-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    line-height: 1.4;
  }

  body.projects-page .project-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  body.projects-page .project-card h2 a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  /* External-link hint on linked project titles. */
  body.projects-page .project-card h2 a::after {
    content: " ↗";
    font-size: 0.8em;
    color: var(--text-muted, #666);
  }

  body.projects-page .project-card p {
    margin: 0;
  }

  body.projects-page .project-card p + p {
    margin-top: 0.75rem;
  }

  /* Optional meta line: a paragraph holding nothing but an <em> right
     after the title renders as a quiet fact row instead of italics,
     e.g. *TypeScript · Gemini · browser-only*. */
  body.projects-page .project-card h2 + p:has(> em:only-child) {
    font-size: 0.875rem;
    color: var(--text-muted, #666);
    margin-bottom: 0.75rem;
  }

  body.projects-page .project-card h2 + p:has(> em:only-child) em {
    font-style: normal;
  }

  @media (prefers-color-scheme: dark) {
    body.projects-page .project-card h2 a::after,
    body.projects-page .project-card h2 + p:has(> em:only-child) {
      color: var(--text-muted, #9ca3af);
    }
  }
</style>
