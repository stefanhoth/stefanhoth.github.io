---
import { getCollection, render } from "astro:content";
import TocSidebar from "@/components/TocSidebar.astro";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages", ({ data }) => data.publish);
  // A `permalink` frontmatter field overrides the filename-derived slug.
  // File-style permalinks (`.md` suffix) still build the folder-style page
  // here — the Worker serves it under the `.md` URL (see worker/index.js).
  return pages.map((page) => ({
    params: { slug: (page.data.permalink ?? page.id).replace(/\.md$/, "") },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);

// `template: sidebar` (frontmatter) renders the content with a sidebar
// linking to every h2. The headings come out of the markdown build, so a
// page without any h2s falls back to the plain template.
const useSidebar =
  page.data.template === "sidebar" &&
  headings.some((heading) => heading.depth === 2);

// `template: projects` renders every h2 section as a card — the wrapping
// happens at build time in src/lib/rehypeProjectCards.js; here we only
// set the body class the card styles are scoped to.
const useProjects = page.data.template === "projects";

const bodyClass = useSidebar
  ? "toc-page"
  : useProjects
    ? "projects-page"
    : undefined;
---

<Layout
  title={page.data.title}
  description={page.data.description}
  bodyClass={bodyClass}
>
  {
    useSidebar ? (
      <div class="toc-layout">
        <aside class="toc-col">
          <TocSidebar headings={headings} />
        </aside>
        <article class="prose">
          <Content />
        </article>
      </div>
    ) : (
      <article class="prose">
        <Content />
      </article>
    )
  }
</Layout>

<style>
  .toc-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .toc-layout {
      grid-template-columns: minmax(0, 600px) 220px;
      gap: 2.5rem;
    }

    /* Content left, sidebar right; it stays in view while scrolling,
       parked below the sticky site header. */
    .toc-col {
      order: 2;
      position: sticky;
      top: 5rem;
    }
  }
</style>

<style is:global>
  /* Layout.astro caps the body at 600px for the single-column pages;
     the sidebar template needs room for the extra column. */
  body.toc-page {
    max-width: 900px;
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  /* Anchor jumps land below the sticky site header. */
  article.prose :is(h2, h3, h4) {
    scroll-margin-top: 5rem;
  }

  /* template: projects — each h2 section arrives pre-wrapped in
     <section class="project-card"> with an icon tile, a per-project
     --project-hue, and chip-ified meta lines (src/lib/rehypeProjectCards.js).

     Layout: the page widens to 900px; the first project is featured
     full-width, the rest flow into a two-column grid. Intro text keeps
     a comfortable reading measure. */
  body.projects-page {
    max-width: 900px;
    /* Soft ambient color wash for the frosted-glass cards to pick up.
       (The body background propagates to the canvas, so this spans the
       whole viewport.) */
    background-image:
      radial-gradient(
        45rem 30rem at 82% -8%,
        oklch(0.85 0.07 255 / 0.5),
        transparent 70%
      ),
      radial-gradient(
        40rem 30rem at 8% 55%,
        oklch(0.88 0.06 160 / 0.45),
        transparent 70%
      ),
      radial-gradient(
        36rem 26rem at 95% 90%,
        oklch(0.88 0.06 40 / 0.4),
        transparent 70%
      );
    background-attachment: fixed;
  }

  body.projects-page article.prose {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    max-width: none;
  }

  body.projects-page article.prose > :not(.project-card) {
    grid-column: 1 / -1;
    max-width: 65ch;
    margin-top: 0;
    margin-bottom: 0;
  }

  body.projects-page .project-card {
    grid-column: auto;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 0;
    transition:
      border-color 0.15s,
      background 0.15s,
      box-shadow 0.15s,
      transform 0.15s;
  }

  /* Frosted glass: translucent surface blurring the ambient wash
     behind it; hover/focus tints the glass with the project's hue. */
  @supports (backdrop-filter: blur(1px)) {
    body.projects-page .project-card {
      background: color-mix(in oklab, var(--card-bg) 62%, transparent);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }
  }

  body.projects-page .project-card:hover,
  body.projects-page .project-card:focus-within {
    border-color: oklch(0.65 0.12 var(--project-hue));
    background: color-mix(
      in oklab,
      var(--card-bg) 70%,
      oklch(0.85 0.06 var(--project-hue) / 0.6)
    );
    box-shadow: 0 12px 32px -12px oklch(0.55 0.12 var(--project-hue) / 0.35);
    transform: translateY(-2px);
  }

  /* The first project is the headliner. */
  body.projects-page .project-card:first-of-type {
    grid-column: 1 / -1;
  }

  @media (max-width: 700px) {
    body.projects-page article.prose {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  body.projects-page .project-card-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 0.75rem;
  }

  /* Icon tile: leading emoji from the title, or a letter monogram,
     tinted with the project's stable hue. */
  body.projects-page .project-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    border-radius: 10px;
    font-size: 1.25rem;
    font-weight: 700;
    background: oklch(0.93 0.05 var(--project-hue));
    color: oklch(0.45 0.13 var(--project-hue));
  }

  body.projects-page .project-card:first-of-type .project-icon {
    width: 3.25rem;
    height: 3.25rem;
    font-size: 1.5rem;
  }

  body.projects-page .project-card h2 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  body.projects-page .project-card:first-of-type h2 {
    font-size: 1.5rem;
  }

  body.projects-page .project-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  body.projects-page .project-card h2 a:hover {
    color: oklch(0.55 0.15 var(--project-hue));
    text-decoration: underline;
  }

  /* External-link hint on linked project titles. */
  body.projects-page .project-card h2 a::after {
    content: " ↗";
    font-size: 0.8em;
    color: var(--text-muted, #666);
  }

  body.projects-page .project-card p {
    margin: 0;
  }

  body.projects-page .project-card p + p {
    margin-top: 0.75rem;
  }

  /* Meta line chips (split from the *em* line by the rehype plugin). */
  body.projects-page .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.875rem;
  }

  body.projects-page .project-meta .chip {
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    background: oklch(0.93 0.03 var(--project-hue));
    color: oklch(0.4 0.08 var(--project-hue));
  }

  /* Pitch: the strong-only paragraph right after the chips. */
  body.projects-page .project-pitch {
    font-size: 1.05rem;
    line-height: 1.45;
  }

  body.projects-page .project-card .project-pitch + p {
    margin-top: 0.625rem;
  }

  /* Collapsible sections (h3 groups → details), e.g. "The story". */
  body.projects-page .project-details {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  body.projects-page .project-details summary {
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted, #666);
  }

  body.projects-page .project-details summary:hover {
    color: oklch(0.55 0.13 var(--project-hue));
  }

  body.projects-page .project-details[open] summary {
    margin-bottom: 0.5rem;
  }

  body.projects-page .project-details p {
    font-size: 0.95rem;
  }

  /* Action row: the trailing all-links bullet list. */
  body.projects-page .project-links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding: 0;
  }

  body.projects-page .project-links li {
    margin: 0;
    padding: 0;
  }

  body.projects-page .project-links a {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text);
  }

  body.projects-page .project-links a::after {
    content: " ↗";
    font-size: 0.8em;
    color: var(--text-muted, #666);
  }

  body.projects-page .project-links a:hover {
    border-color: oklch(0.65 0.12 var(--project-hue));
    color: oklch(0.5 0.13 var(--project-hue));
  }

  @media (prefers-color-scheme: dark) {
    body.projects-page {
      background-image:
        radial-gradient(
          45rem 30rem at 82% -8%,
          oklch(0.32 0.08 255 / 0.55),
          transparent 70%
        ),
        radial-gradient(
          40rem 30rem at 8% 55%,
          oklch(0.3 0.07 160 / 0.5),
          transparent 70%
        ),
        radial-gradient(
          36rem 26rem at 95% 90%,
          oklch(0.3 0.07 40 / 0.45),
          transparent 70%
        );
    }

    body.projects-page .project-card:hover,
    body.projects-page .project-card:focus-within {
      border-color: oklch(0.55 0.1 var(--project-hue));
      background: color-mix(
        in oklab,
        var(--card-bg) 72%,
        oklch(0.35 0.07 var(--project-hue) / 0.7)
      );
      box-shadow: 0 12px 32px -12px oklch(0.3 0.08 var(--project-hue) / 0.6);
    }

    body.projects-page .project-icon {
      background: oklch(0.32 0.06 var(--project-hue));
      color: oklch(0.85 0.09 var(--project-hue));
    }

    body.projects-page .project-card h2 a:hover {
      color: oklch(0.78 0.12 var(--project-hue));
    }

    body.projects-page .project-card h2 a::after {
      color: var(--text-muted, #9ca3af);
    }

    body.projects-page .project-meta .chip {
      background: oklch(0.3 0.04 var(--project-hue));
      color: oklch(0.82 0.06 var(--project-hue));
    }

    body.projects-page .project-details summary:hover {
      color: oklch(0.78 0.1 var(--project-hue));
    }

    body.projects-page .project-links a:hover {
      color: oklch(0.78 0.12 var(--project-hue));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    body.projects-page .project-card,
    body.projects-page .project-card:hover {
      transition: none;
      transform: none;
    }
  }
</style>
