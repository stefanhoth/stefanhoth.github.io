---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";

const currentYear = new Date().getFullYear();

const {
  title = "Stefan Hoth | Engineering Leader",
  description = "Engineering Leader building high-trust engineering organizations. Currently open to Director or Head of Engineering roles, remote-first.",
  bodyClass,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Engineering Manager, Engineering Leader, Director of Engineering, Head of Engineering, Software Engineering, Remote-First, Platform Engineering, Engineering Org Development"
    />
    <meta name="author" content="Stefan Hoth" />
    <title>{title}</title>
    <link rel="canonical" href="https://stefanhoth.com" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS"
      href="/feed.xml"
    />

    <!-- Favicons -->
    <link rel="shortcut icon" href="/img/favs/favicon.ico" />
    <link rel="icon" sizes="16x16 32x32 64x64" href="/img/favs/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="196x196"
      href="/img/favs/favicon-192.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="160x160"
      href="/img/favs/favicon-160.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/img/favs/favicon-96.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="64x64"
      href="/img/favs/favicon-64.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/img/favs/favicon-32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/img/favs/favicon-16.png"
    />
    <link rel="apple-touch-icon" href="/img/favs/favicon-57.png" />
    <link
      rel="apple-touch-icon"
      sizes="114x114"
      href="/img/favs/favicon-114.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="72x72"
      href="/img/favs/favicon-72.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="144x144"
      href="/img/favs/favicon-144.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="60x60"
      href="/img/favs/favicon-60.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href="/img/favs/favicon-120.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="76x76"
      href="/img/favs/favicon-76.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href="/img/favs/favicon-152.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/img/favs/favicon-180.png"
    />
    <meta name="msapplication-TileColor" content="#FFFFFF" />
    <meta name="msapplication-TileImage" content="/img/favs/favicon-144.png" />
    <meta name="msapplication-config" content="/img/favs/browserconfig.xml" />
  </head>
  <body class={bodyClass}>
    <style is:global>
      :root {
        --bg: #fafafa;
        --text: #111;
        --text-muted: #5f6672;
        --accent: #0d6efd;
        --open-dot: #059669;
        --card-bg: white;
        --border: #e5e7eb;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #111;
          --text: #fafafa;
          --text-muted: #9ca3af;
          --open-dot: #34d399;
          --card-bg: #1f2937;
          --border: #374151;
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 2rem 1rem;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        max-width: 600px;
        margin-inline: auto;
      }

      .profile {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
      }

      /* The photo is a brush-stroke cutout with transparency — keep its
         natural shape, no crop or frame. */
      .photo {
        width: 112px;
        height: 112px;
        flex-shrink: 0;
      }

      h1 {
        font-size: 2rem;
        margin: 0 0 0.25rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }

      .tagline {
        font-size: 1.05rem;
        color: var(--text-muted);
        margin: 0 0 0.5rem;
      }

      .location {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin: 0;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }

      .location::before {
        content: "📍";
        font-size: 1rem;
        display: inline-block;
      }

      .job-hunt {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem 1.25rem;
        font-size: 1rem;
        margin-bottom: 2rem;
      }

      .job-hunt::before {
        content: "";
        display: inline-block;
        width: 0.55em;
        height: 0.55em;
        border-radius: 50%;
        background: var(--open-dot);
        margin-right: 0.6em;
      }

      .about {
        margin-bottom: 2rem;
      }

      .about p {
        margin-bottom: 1rem;
      }

      .latest-post {
        margin-bottom: 2rem;
        padding: 1rem 1.25rem;
        border-left: 3px solid var(--accent);
      }

      .latest-post .label {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 0 0 0.25rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .latest-post h3 {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 0;
      }

      .latest-post .date {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 0.25rem 0 0;
      }

      .latest-post a {
        text-decoration: none;
        color: inherit;
      }

      .latest-post a:hover h3 {
        text-decoration: underline;
      }

      .section-title {
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin: 0 0 1rem;
      }

      .links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 2.5rem;
      }

      .link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--card-bg);
        padding: 0.5rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        color: var(--text);
        font-size: 0.95rem;
        border: 1px solid var(--border);
        transition:
          border-color 0.15s,
          color 0.15s;
      }

      .link:hover {
        border-color: var(--accent);
        color: var(--accent);
      }

      .link .logo {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }

      form {
        background: var(--card-bg);
        padding: 2rem;
        border-radius: 12px;
        border: 1px solid var(--border);
      }

      .site-footer {
        margin-top: 3rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        font-size: 0.875rem;
        color: var(--text-muted);
      }

      .contact-status {
        padding: 1rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-weight: 600;
        border: 1px solid transparent;
      }

      .contact-status--success {
        background: #ecfdf5;
        border-color: #10b981;
        color: #065f46;
      }

      .contact-status--error {
        background: #fef2f2;
        border-color: #ef4444;
        color: #991b1b;
      }

      @media (prefers-color-scheme: dark) {
        .contact-status--success {
          background: rgba(16, 185, 129, 0.15);
          color: #6ee7b7;
        }

        .contact-status--error {
          background: rgba(239, 68, 68, 0.15);
          color: #fca5a5;
        }
      }

      input,
      textarea {
        width: 100%;
        padding: 0.75rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        color: var(--text);
        font-family: inherit;
        font-size: 1rem;
      }

      input:focus,
      textarea:focus {
        outline: none;
        border-color: var(--accent);
      }

      button {
        background: var(--accent);
        color: white;
        padding: 1rem 2rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition: background 0.2s;
        font-size: 1rem;
      }

      button:hover {
        background: #0b5ed7;
      }

      button:disabled {
        background: var(--border);
        color: var(--text);
        opacity: 0.6;
        cursor: not-allowed;
      }

      button:disabled:hover {
        background: var(--border);
      }

      .hidden {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }

      @media (max-width: 640px) {
        body {
          padding: 1rem;
        }
      }

      @media (max-width: 480px) {
        .profile {
          flex-direction: column;
          text-align: center;
          gap: 1rem;
        }

        h1 {
          font-size: 1.75rem;
        }
      }
    </style>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <footer class="site-footer">© {currentYear} Stefan Hoth</footer>
  </body>
</html>
