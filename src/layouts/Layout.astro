---
import "../styles/global.css";

const {
  title = "Stefan Hoth | Engineering Leader",
  description = "Engineering Leader building high-trust engineering organizations. Currently open to Director or Head of Engineering roles, remote-first.",
  bodyClass,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Engineering Manager, Engineering Leader, Director of Engineering, Head of Engineering, Software Engineering, Remote-First, Platform Engineering, Engineering Org Development"
    />
    <meta name="author" content="Stefan Hoth" />
    <title>{title}</title>
    <link rel="canonical" href="https://stefanhoth.com" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS"
      href="/feed.xml"
    />

    <!-- Favicons -->
    <link rel="shortcut icon" href="/img/favs/favicon.ico" />
    <link rel="icon" sizes="16x16 32x32 64x64" href="/img/favs/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="196x196"
      href="/img/favs/favicon-192.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="160x160"
      href="/img/favs/favicon-160.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/img/favs/favicon-96.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="64x64"
      href="/img/favs/favicon-64.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/img/favs/favicon-32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/img/favs/favicon-16.png"
    />
    <link rel="apple-touch-icon" href="/img/favs/favicon-57.png" />
    <link
      rel="apple-touch-icon"
      sizes="114x114"
      href="/img/favs/favicon-114.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="72x72"
      href="/img/favs/favicon-72.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="144x144"
      href="/img/favs/favicon-144.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="60x60"
      href="/img/favs/favicon-60.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href="/img/favs/favicon-120.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="76x76"
      href="/img/favs/favicon-76.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href="/img/favs/favicon-152.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/img/favs/favicon-180.png"
    />
    <meta name="msapplication-TileColor" content="#FFFFFF" />
    <meta name="msapplication-TileImage" content="/img/favs/favicon-144.png" />
    <meta name="msapplication-config" content="/img/favs/browserconfig.xml" />
  </head>
  <body class={bodyClass}>
    <style is:global>
      :root {
        --bg: #fafafa;
        --text: #111;
        --accent: #0d6efd;
        --card-bg: white;
        --border: #e5e7eb;
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #111;
          --text: #fafafa;
          --card-bg: #1f2937;
          --border: #374151;
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 2rem 1rem;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        max-width: 600px;
        margin-inline: auto;
      }

      .profile {
        text-align: center;
        margin-bottom: 1.5rem;
      }

      .photo {
        width: 300px;
        height: 300px;
        object-fit: cover;
        margin: auto;
      }

      h1 {
        font-size: 2.5rem;
        margin: 0 0 0.5rem;
        font-weight: 700;
      }

      .tagline {
        font-size: 1.1rem;
        color: #666;
        margin: 0 0 0.5rem;
      }

      @media (prefers-color-scheme: dark) {
        .tagline {
          color: #9ca3af;
        }
      }

      .location {
        font-size: 0.95rem;
        color: #666;
        margin: 0;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }

      .location::before {
        content: "📍";
        font-size: 1rem;
        display: inline-block;
      }

      @media (prefers-color-scheme: dark) {
        .location {
          color: #9ca3af;
        }
      }

      .job-hunt {
        background: linear-gradient(135deg, var(--accent), #0ea5e9);
        color: white;
        padding: 1.5rem;
        border-radius: 12px;
        text-align: center;
        font-weight: 600;
        font-size: 1.2rem;
        margin-bottom: 2rem;
        box-shadow: var(--shadow);
      }

      .job-hunt strong {
        display: block;
        margin-top: 0.5rem;
      }

      .about {
        margin-bottom: 2rem;
      }

      .about p {
        margin-bottom: 1rem;
      }

      .latest-post {
        margin-bottom: 2rem;
        padding: 1rem 1.25rem;
        border-left: 3px solid var(--accent);
      }

      .latest-post .label {
        font-size: 0.875rem;
        color: #666;
        margin: 0 0 0.25rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .latest-post h3 {
        font-size: 1.125rem;
        margin: 0;
      }

      .latest-post .date {
        font-size: 0.875rem;
        color: #666;
        margin: 0.25rem 0 0;
      }

      .latest-post a {
        text-decoration: none;
        color: inherit;
      }

      .latest-post a:hover h3 {
        text-decoration: underline;
      }

      @media (prefers-color-scheme: dark) {
        .latest-post .label,
        .latest-post .date {
          color: #9ca3af;
        }
      }

      .links {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
      }

      .link {
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--card-bg);
        padding: 1.5rem;
        border-radius: 12px;
        text-decoration: none;
        color: var(--text);
        border: 1px solid var(--border);
        transition: all 0.2s;
        box-shadow: var(--shadow);
        aspect-ratio: 1;
      }

      .link:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        border-color: var(--accent);
        color: var(--accent);
      }

      .link .logo {
        width: 70%;
        height: auto;
        max-width: 120px;
        transition: transform 0.2s;
      }

      .link:hover .logo {
        transform: scale(1.1);
      }

      form {
        background: var(--card-bg);
        padding: 2rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
      }

      .contact-status {
        padding: 1rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-weight: 600;
        border: 1px solid transparent;
      }

      .contact-status--success {
        background: #ecfdf5;
        border-color: #10b981;
        color: #065f46;
      }

      .contact-status--error {
        background: #fef2f2;
        border-color: #ef4444;
        color: #991b1b;
      }

      @media (prefers-color-scheme: dark) {
        .contact-status--success {
          background: rgba(16, 185, 129, 0.15);
          color: #6ee7b7;
        }

        .contact-status--error {
          background: rgba(239, 68, 68, 0.15);
          color: #fca5a5;
        }
      }

      input,
      textarea {
        width: 100%;
        padding: 0.75rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        color: var(--text);
        font-family: inherit;
        font-size: 1rem;
      }

      input:focus,
      textarea:focus {
        outline: none;
        border-color: var(--accent);
      }

      button {
        background: var(--accent);
        color: white;
        padding: 1rem 2rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition: background 0.2s;
        font-size: 1rem;
      }

      button:hover {
        background: #0b5ed7;
      }

      button:disabled {
        background: var(--border);
        color: var(--text);
        opacity: 0.6;
        cursor: not-allowed;
      }

      button:disabled:hover {
        background: var(--border);
      }

      .hidden {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }

      @media (max-width: 640px) {
        body {
          padding: 1rem;
        }

        h1 {
          font-size: 2rem;
        }

        .job-hunt {
          font-size: 1rem;
          padding: 1.25rem;
        }

        .links {
          grid-template-columns: 1fr;
        }
      }
    </style>
    <slot />
  </body>
</html>
