{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "stefanhoth-com",
  "main": "./worker/index.js",
  "compatibility_date": "2026-07-06",
  "preview_urls": true,
  "routes": [{ "pattern": "stefanhoth.com", "custom_domain": true }],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
